APP_ENV=development
DATABASE_URL=postgres://lance:lance@localhost:5432/lance
OPENCLAW_API_KEY=TODO_fill_in
OPENCLAW_BASE_URL=https://api.openclaw.ai/v1
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
JUDGE_AUTHORITY_SECRET=TODO_fill_in_soroban_key
ESCROW_CONTRACT_ID=TODO_after_deploy
REPUTATION_CONTRACT_ID=TODO_after_deploy
JOB_REGISTRY_CONTRACT_ID=TODO_after_deploy
PORT=3001
RUST_LOG=backend=debug,tower_http=debug
# Set to "json" for structured JSON log output (e.g. in production)
LOG_FORMAT=pretty

# Storage Audit Configuration
# Interval between storage audits in seconds (default: 3600 = 1 hour)
STORAGE_AUDIT_INTERVAL_SECS=3600
# Maximum acceptable growth rate per audit cycle in percent (default: 50.0)
STORAGE_AUDIT_MAX_GROWTH_PERCENT=50.0
# Threshold for table size anomaly detection in bytes (default: 100000000 = 100MB)
STORAGE_AUDIT_ANOMALY_THRESHOLD_BYTES=100000000
# Enable structured logging of storage anomalies (default: true)
STORAGE_AUDIT_ENABLE_ALERTS=true
