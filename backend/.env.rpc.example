# Enhanced RPC Client Configuration
# Copy to .env and adjust values as needed

# ============================================================================
# RPC Endpoint Configuration
# ============================================================================
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# ============================================================================
# Rate Limiting
# ============================================================================
# Minimum time between RPC requests (milliseconds)
# Lower = faster processing, but may hit rate limits
# Higher = more respectful to provider, but slower
# Default: 100ms (allows 10 requests/second)
INDEXER_RPC_RATE_LIMIT_MS=100

# ============================================================================
# Retry Policy
# ============================================================================
# Maximum number of retry attempts for failed requests
# Default: 5
INDEXER_RPC_RETRY_MAX_ATTEMPTS=5

# Initial backoff delay for first retry (milliseconds)
# Default: 200ms
INDEXER_RPC_RETRY_INITIAL_BACKOFF_MS=200

# Maximum backoff delay (milliseconds)
# Backoff grows exponentially but caps at this value
# Default: 3000ms (3 seconds)
INDEXER_RPC_RETRY_MAX_BACKOFF_MS=3000

# Enable jitter to prevent thundering herd
# Adds random 0-25% to backoff delay
# Values: true, false, 1, 0, yes, no, on, off
# Default: true
INDEXER_RPC_RETRY_JITTER_ENABLED=true

# ============================================================================
# Request Timeout
# ============================================================================
# Maximum time to wait for RPC response (milliseconds)
# Prevents hanging requests
# Default: 10000ms (10 seconds)
INDEXER_RPC_TIMEOUT_MS=10000

# ============================================================================
# Circuit Breaker
# ============================================================================
# Enable circuit breaker pattern
# Prevents cascading failures by failing fast when RPC is down
# Default: true
INDEXER_CIRCUIT_BREAKER_ENABLED=true

# Number of consecutive failures before opening circuit
# Default: 5
INDEXER_CIRCUIT_BREAKER_THRESHOLD=5

# Time to wait before testing recovery (milliseconds)
# After this timeout, circuit enters half-open state
# Default: 30000ms (30 seconds)
INDEXER_CIRCUIT_BREAKER_TIMEOUT_MS=30000

# ============================================================================
# Polling Intervals
# ============================================================================
# Polling interval when caught up with network (milliseconds)
# Default: 1000ms (1 second)
INDEXER_IDLE_POLL_MS=1000

# Polling interval when lagging behind network (milliseconds)
# Used when more than 10 ledgers behind
# Default: 500ms (0.5 seconds)
INDEXER_ACTIVE_POLL_MS=500

# ============================================================================
# Worker Retry Policy
# ============================================================================
# Retry policy for the worker loop (not individual RPC requests)
# Maximum retry attempts for worker cycle failures
# Default: 4
INDEXER_WORKER_RETRY_MAX_ATTEMPTS=4

# Initial backoff for worker retries (milliseconds)
# Default: 1000ms
INDEXER_WORKER_RETRY_INITIAL_BACKOFF_MS=1000

# Maximum backoff for worker retries (milliseconds)
# Default: 60000ms (60 seconds)
INDEXER_WORKER_RETRY_MAX_BACKOFF_MS=60000

# Enable jitter for worker retries
# Default: true
INDEXER_WORKER_RETRY_JITTER_ENABLED=true

# ============================================================================
# Performance Tuning Presets
# ============================================================================

# PRESET: AGGRESSIVE (Fastest, may hit rate limits)
# INDEXER_RPC_RATE_LIMIT_MS=50
# INDEXER_RPC_RETRY_MAX_ATTEMPTS=3
# INDEXER_RPC_RETRY_INITIAL_BACKOFF_MS=100
# INDEXER_RPC_RETRY_MAX_BACKOFF_MS=2000
# INDEXER_IDLE_POLL_MS=500
# INDEXER_ACTIVE_POLL_MS=250

# PRESET: BALANCED (Default, good for most cases)
# INDEXER_RPC_RATE_LIMIT_MS=100
# INDEXER_RPC_RETRY_MAX_ATTEMPTS=5
# INDEXER_RPC_RETRY_INITIAL_BACKOFF_MS=200
# INDEXER_RPC_RETRY_MAX_BACKOFF_MS=3000
# INDEXER_IDLE_POLL_MS=1000
# INDEXER_ACTIVE_POLL_MS=500

# PRESET: CONSERVATIVE (Slower, very respectful to provider)
# INDEXER_RPC_RATE_LIMIT_MS=250
# INDEXER_RPC_RETRY_MAX_ATTEMPTS=7
# INDEXER_RPC_RETRY_INITIAL_BACKOFF_MS=500
# INDEXER_RPC_RETRY_MAX_BACKOFF_MS=5000
# INDEXER_IDLE_POLL_MS=2000
# INDEXER_ACTIVE_POLL_MS=1000

# ============================================================================
# Monitoring & Alerting
# ============================================================================
# Maximum acceptable ledger lag for health checks
# Default: 5
INDEXER_MAX_LEDGER_LAG=5

# ============================================================================
# Notes
# ============================================================================
# 
# Performance Target: Process new ledgers within 5 seconds of closure
# 
# Typical Processing Breakdown:
# - RPC Poll Delay:        500-1000ms
# - RPC Fetch Events:      100-500ms
# - Process Events:        100-2000ms
# - Database Transaction:  50-200ms
# - Commit Checkpoint:     10-50ms
# Total:                   760-3750ms ✓
#
# Tuning Tips:
# 1. Lower RATE_LIMIT_MS for faster processing (watch for 429 errors)
# 2. Increase RETRY_MAX_ATTEMPTS for unreliable networks
# 3. Lower ACTIVE_POLL_MS to catch up faster when lagging
# 4. Adjust CIRCUIT_BREAKER_THRESHOLD based on RPC reliability
# 5. Monitor processing_duration_ms in ledger_processing_log table
#
# Troubleshooting:
# - High latency: Reduce RATE_LIMIT_MS, check RPC endpoint
# - Rate limit errors: Increase RATE_LIMIT_MS
# - Circuit breaker opens: Check RPC health, increase THRESHOLD
# - Timeouts: Increase RPC_TIMEOUT_MS, check network
# - Slow processing: Check database performance, optimize queries
